# ── LLM ──
CLAUDE_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Mem0 Embeddings (OpenAI-compatible) ──
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ── 数据存储路径 ──
EVOLUTION_ROOT=/data/evolution

# ── 用户标识 ──
EVOLUTION_USER_ID=yjh

# ── 通知 - Email (可选) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_TO=recipient@email.com

# ── 通知 - Telegram (推荐用于手机交互) ──
# 1. 在 Telegram 搜索 @BotFather，发送 /newbot 创建 Bot
# 2. 保存 Bot Token（格式：123456789:ABCdefGHIjklMNOpqrsTUVwxyz）
# 3. 与你的 Bot 对话，发送 /start
# 4. 访问 https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates 获取 chat_id
TG_ENABLED=true
TG_BOT_TOKEN=123456:ABC-xxx
TG_CHAT_ID=123456789

# ── 通知 - Notion (可选) ──
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxx

# ── RSSHub (可选) ──
RSSHUB_URL=http://localhost:1200
